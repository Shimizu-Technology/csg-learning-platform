# ============================================
# CSG Learning Platform — Frontend Environment
# ============================================

# API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000

# ---- Clerk Authentication ----

# Clerk publishable key (from Clerk dashboard → API Keys)
# Required. When missing, the app shows a configuration error.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Browser push public key from WEB_PUSH_PUBLIC_KEY in the API environment.
# Leave blank to hide push opt-in controls.
# VITE_WEB_PUSH_PUBLIC_KEY=...

# ---- Analytics (PostHog) ----

# PostHog project API key (from PostHog → Project Settings)
# VITE_PUBLIC_POSTHOG_KEY=phc_...

# PostHog ingest endpoint
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
