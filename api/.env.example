# ============================================
# CSG Learning Platform — API Environment
# ============================================

# Frontend URL for CORS (must match exactly, no trailing slash)
FRONTEND_URL=http://localhost:5173

# ---- Clerk Authentication ----

# Clerk issuer URL (from Clerk dashboard → JWT Templates or API Keys)
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# Clerk Backend API key (optional — for enriching user data when JWT lacks email/name)
# CLERK_SECRET_KEY=sk_test_...

# Optional: explicit JWKS URL (overrides CLERK_ISSUER-based URL)
# CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Optional: JWT audience verification
# CLERK_AUDIENCE=https://your-api-audience.example.com

# ---- Email (Resend) ----

# Resend API key for transactional emails (invite emails)
# Get from https://resend.com/api-keys
# RESEND_API_KEY=re_...

# From address for outgoing emails
MAILER_FROM_EMAIL=noreply@codeschoolofguam.com

# ---- GitHub Integration ----

# Personal access token with `repo` scope for syncing student repos and org invitations
# GITHUB_ORGANIZATION_ADMIN_TOKEN=ghp_...

# ---- Database ----

# Production only (Neon PostgreSQL) — local dev uses Rails defaults
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
