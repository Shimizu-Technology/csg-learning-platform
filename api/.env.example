# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Clerk JWT verification (JWKS URL is built from CLERK_ISSUER)
# Get from Clerk dashboard: https://dashboard.clerk.com
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# Clerk Backend API key (for enriching user data when JWT lacks email/name)
# CLERK_SECRET_KEY=sk_test_...

# Optional: explicit JWKS URL (overrides CLERK_ISSUER-based URL)
# CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Optional: JWT audience verification
# CLERK_AUDIENCE=https://your-api-audience.example.com

# Resend transactional email (for invite emails)
# Get from https://resend.com/api-keys
# RESEND_API_KEY=re_...
MAILER_FROM_EMAIL=noreply@yourdomain.com

# GitHub token for syncing student repos and org invitations
# Personal access token with `repo` scope — same one used in csg-prework-grader
# GITHUB_ORGANIZATION_ADMIN_TOKEN=ghp_...

# Database (production only - Neon)
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/db?sslmode=require
