{
  "expo": {
    "name": "CSG Connect",
    "slug": "csg-connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "csgconnect",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": {
        "light": "./assets/images/icon-light.png",
        "dark": "./assets/images/icon-dark.png",
        "tinted": "./assets/images/icon-tinted.png"
      },
      "bundleIdentifier": "com.codeschoolofguam.connect",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#0B0D12",
        "foregroundImage": "./assets/images/icon-foreground.png",
        "monochromeImage": "./assets/images/icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.codeschoolofguam.connect",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-dev-client",
        {
          "toolsButton": false,
          "skipOnboarding": true,
          "showMenuAtLaunch": false
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0D12",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180
        }
      ],
      "@clerk/expo",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#C51D34",
          "defaultChannel": "messages"
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "CSG Connect uses selected photos only when you choose to share them in a conversation.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-sharing",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c6326478-e200-4aba-8614-806ca5f8e03a"
      }
    },
    "owner": "shimizutechnology"
  }
}
